      "margin": "15px 0 15px 0"
    },
      {
        "property": "zen.tidytabs.ai.group-namer",
        "label": "Grouping engine",
        "type": "dropdown",
        "defaultValue": "hybrid",
        "options": [
          { "label": "Hybrid (OpenRouter → Local AI → Fuzzy)", "value": "hybrid" },
          { "label": "OpenRouter (remote LLM only)", "value": "openrouter" },
          { "label": "Local AI — Firefox ML (on-device)", "value": "local" },
          { "label": "Fuzzy (deterministic only)", "value": "fuzzy" }
        ]
      },
      {
        "property": "zen.tidytabs.grouping-strength",
        "label": "Grouping strength (0 = conservative, 1 = aggressive)",
        "type": "string",
        "defaultValue": "0.5",
        "placeholder": "e.g. 0.5"
      },
      {
        "property": "zen.tidytabs.group-leftovers-as-misc",
        "label": "Group leftover tabs as Miscellaneous",
        "type": "checkbox",
        "defaultValue": true
      },

    {
