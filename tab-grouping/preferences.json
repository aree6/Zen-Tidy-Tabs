          { "label": "GLM 4.5 Air (balanced)", "value": "glm-air" },
          { "label": "Llama 3.3 70B (most accurate)", "value": "llama33-70b" },
          { "label": "Gemma 3 27B (balanced)", "value": "gemma3-27b" }
        ]
      },
      {
        "property": "zen.tidytabs.openrouter.api-key",
